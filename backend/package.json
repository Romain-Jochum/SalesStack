{
  "name": "sales-engine",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "tsc",
    "start:api": "node dist/server.js",
    "start:worker": "node dist/workers/index.js",
    "dev:api": "tsx watch src/server.ts",
    "dev:worker": "tsx watch src/workers/index.ts",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'",
    "typecheck": "tsc --noEmit",
    "test:unit": "jest --testPathPattern=tests/unit --passWithNoTests",
    "test:integration": "jest --testPathPattern=tests/integration --runInBand --passWithNoTests",
    "test": "jest --runInBand --passWithNoTests",
    "prepare": "cd .. && husky",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "prisma:generate": "prisma generate"
  },
  "lint-staged": {
    "src/**/*.ts": "eslint --fix",
    "tests/**/*.ts": "eslint --fix",
    "**/*.ts": "prettier --write"
  },
  "dependencies": {
    "@fastify/cors": "11.2.0",
    "@fastify/helmet": "13.0.2",
    "@fastify/rate-limit": "10.3.0",
    "@fastify/swagger": "9.7.0",
    "@fastify/swagger-ui": "5.2.5",
    "@prisma/client": "7.6.0",
    "@sentry/node": "10.47.0",
    "@sinclair/typebox": "0.34.49",
    "bullmq": "5.73.0",
    "fastify": "5.8.4",
    "ioredis": "5.10.1",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "prom-client": "15.1.3"
  },
  "devDependencies": {
    "@types/jest": "29.5.14",
    "@types/node": "25.5.2",
    "@typescript-eslint/eslint-plugin": "7.18.0",
    "@typescript-eslint/parser": "7.18.0",
    "eslint": "8.57.1",
    "husky": "9.1.7",
    "jest": "29.7.0",
    "lint-staged": "16.4.0",
    "prettier": "3.8.1",
    "prisma": "7.6.0",
    "testcontainers": "11.13.0",
    "ts-jest": "29.4.9",
    "ts-node": "10.9.2",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  }
}
